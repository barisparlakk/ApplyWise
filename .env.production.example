# Public entry point. Terminate TLS with your platform or reverse proxy before forwarding to WEB_PORT.
WEB_PORT=3000
NEXTAUTH_URL=https://applywise.example.com
CORS_ORIGINS=https://applywise.example.com

# Generate independent values with: openssl rand -base64 48
NEXTAUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
AUTH_JWT_SECRET=replace-with-a-different-random-secret-at-least-32-characters
AUTH_JWT_AUDIENCE=applywise-api
AUTH_JWT_ISSUER=applywise-web

# Use URL-safe credentials and keep this URL aligned with POSTGRES_* below.
POSTGRES_USER=applywise
POSTGRES_PASSWORD=replace-with-a-url-safe-production-password
POSTGRES_DB=applywise
DATABASE_URL=postgresql+psycopg://applywise:replace-with-a-url-safe-production-password@postgres:5432/applywise
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=api,localhost,127.0.0.1
MAX_REQUEST_BODY_BYTES=16777216
API_PROXY_TIMEOUT_MS=120000
AI_ACTIONS_PER_HOUR=30
AI_GLOBAL_ACTIONS_PER_DAY=100
BACKGROUND_JOBS_ENABLED=true
WORKER_PROCESSES=1
WORKER_THREADS=2

# Cloudflare Workers AI has a limited free daily allocation. Local fallback keeps beta workflows
# available when that quota is exhausted, while runtime validation prevents accidental local-only AI.
REQUIRE_EXTERNAL_LLM=true
REQUIRE_EXTERNAL_EMBEDDINGS=true
AI_ALLOW_LOCAL_FALLBACK=true
LLM_PROVIDER=cloudflare
EMBEDDING_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=replace-with-your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-your-workers-ai-token
CLOUDFLARE_LLM_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
CLOUDFLARE_EMBEDDING_MODEL=@cf/google/embeddinggemma-300m
CLOUDFLARE_AI_TIMEOUT_SECONDS=30

# Optional OpenAI-compatible replacement for the Cloudflare LLM provider.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
WEB_CONCURRENCY=2

# Configure at least one social provider for production sign-in. The unrestricted local email provider is disabled in production.
GITHUB_ID=replace-with-your-github-oauth-client-id
GITHUB_SECRET=replace-with-your-github-oauth-client-secret
GOOGLE_ID=replace-with-your-google-oauth-client-id
GOOGLE_SECRET=replace-with-your-google-oauth-client-secret
SUPPORT_EMAIL=support@your-domain.example
