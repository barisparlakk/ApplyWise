# Public entry point. Terminate TLS with your platform or reverse proxy before forwarding to WEB_PORT.
WEB_PORT=3000
NEXTAUTH_URL=https://applywise.example.com
CORS_ORIGINS=https://applywise.example.com

# Generate independent values with: openssl rand -base64 48
NEXTAUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
AUTH_JWT_SECRET=replace-with-a-different-random-secret-at-least-32-characters
AUTH_JWT_AUDIENCE=applywise-api
AUTH_JWT_ISSUER=applywise-web

# Use URL-safe credentials and keep this URL aligned with POSTGRES_* below.
POSTGRES_USER=applywise
POSTGRES_PASSWORD=replace-with-a-url-safe-production-password
POSTGRES_DB=applywise
DATABASE_URL=postgresql+psycopg://applywise:replace-with-a-url-safe-production-password@postgres:5432/applywise
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=api,localhost,127.0.0.1
MAX_REQUEST_BODY_BYTES=16777216
API_PROXY_TIMEOUT_MS=120000
AI_ACTIONS_PER_HOUR=30

# A real provider is required for public production. The endpoint must be OpenAI-compatible.
REQUIRE_EXTERNAL_LLM=true
LLM_PROVIDER=openai-compatible
LLM_API_URL=https://your-provider.example/v1/chat/completions
LLM_API_KEY=replace-with-your-provider-api-key
LLM_MODEL=replace-with-your-model-name
LLM_TIMEOUT_SECONDS=30
WEB_CONCURRENCY=2

# Required for production sign-in. The local development email provider is intentionally disabled in production.
GITHUB_ID=replace-with-your-github-oauth-client-id
GITHUB_SECRET=replace-with-your-github-oauth-client-secret
SUPPORT_EMAIL=support@your-domain.example
