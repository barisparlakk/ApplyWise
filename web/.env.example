# Browser calls stay same-origin through the Next.js backend proxy.
NEXT_PUBLIC_API_BASE_URL=/api/backend
# Server-side Next.js calls use the API directly.
API_INTERNAL_URL=http://localhost:8000
NEXT_TELEMETRY_DISABLED=1

# Auth.js local development settings.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-change-me

# JWT values used by Auth.js callbacks and verified by FastAPI.
AUTH_JWT_SECRET=dev-applywise-auth-secret-change-me
AUTH_JWT_AUDIENCE=applywise-api
AUTH_JWT_ISSUER=applywise-web

# Optional GitHub OAuth credentials. Email login works for local demo without these.
GITHUB_ID=
GITHUB_SECRET=
