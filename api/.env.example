# FastAPI runtime
APP_NAME=ApplyWise API
APP_ENV=development

# Local database and broker. Docker Compose overrides DATABASE_URL inside containers.
DATABASE_URL=postgresql+psycopg://applywise:applywise@localhost:5432/applywise
REDIS_URL=redis://localhost:6379/0

# Must match the frontend values so FastAPI can validate Auth.js-issued backend JWTs.
AUTH_JWT_SECRET=dev-applywise-auth-secret-change-me
AUTH_JWT_AUDIENCE=applywise-api
AUTH_JWT_ISSUER=applywise-web

# Defaults to deterministic local analyzers. Configure these only for an external LLM provider.
LLM_PROVIDER=local
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
