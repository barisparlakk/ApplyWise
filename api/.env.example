# FastAPI runtime
APP_NAME=ApplyWise API
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# Local database and broker. Docker Compose overrides DATABASE_URL inside containers.
DATABASE_URL=postgresql+psycopg://applywise:applywise@localhost:5432/applywise
REDIS_URL=redis://localhost:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1,api,testserver
MAX_REQUEST_BODY_BYTES=16777216
AI_ACTIONS_PER_HOUR=30
BACKGROUND_JOBS_ENABLED=true
WORKER_PROCESSES=1
WORKER_THREADS=2

# Must match the frontend values so FastAPI can validate Auth.js-issued backend JWTs.
AUTH_JWT_SECRET=dev-applywise-auth-secret-change-me
AUTH_JWT_AUDIENCE=applywise-api
AUTH_JWT_ISSUER=applywise-web

# Local mode is quota-free and deterministic. The free public beta uses Cloudflare Workers AI.
LLM_PROVIDER=local
EMBEDDING_PROVIDER=local
AI_ALLOW_LOCAL_FALLBACK=true
REQUIRE_EXTERNAL_LLM=false
REQUIRE_EXTERNAL_EMBEDDINGS=false
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_LLM_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
CLOUDFLARE_EMBEDDING_MODEL=@cf/google/embeddinggemma-300m
CLOUDFLARE_AI_TIMEOUT_SECONDS=30

# Optional OpenAI-compatible provider configuration.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
